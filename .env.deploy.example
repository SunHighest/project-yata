# Project YATA — デプロイ設定
# このファイルをコピーして .env.deploy を作成し、実際の認証情報を記入する
# .env.deploy は .gitignore で除外されているため git に含まれない

# さくらインターネット FTP 接続情報
FTP_HOST=your-account.sakura.ne.jp
FTP_USER=your-account
FTP_PASSWORD=your-ftp-password

# サーバー上の公開ディレクトリ（末尾スラッシュなし）
# 例: /home/your-account/www
FTP_REMOTE_DIR=/home/your-account/www

# FTPS (TLS) を使用する場合は true に変更（省略時は plain FTP）
FTP_TLS=false
